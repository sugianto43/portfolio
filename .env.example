# Copy this file to .env.local for local development.
# Vercel: set the same keys under Project Settings -> Environment Variables.

# Public site URL, used for metadataBase, canonical URLs, Open Graph, sitemap.xml,
# robots.txt, and the manifest. Falls back to a hardcoded default in lib/data.ts
# if unset, so this is optional for local dev but should be set in production.
NEXT_PUBLIC_SITE_URL=https://sugianto.dev

# --- CI/CD only (do NOT put these in .env.local) ---
# These are consumed by .github/workflows/ci.yml to deploy via the Vercel CLI.
# Set them as GitHub Actions repository secrets (Settings -> Secrets and variables ->
# Actions), not as environment variables in this file:
#
#   VERCEL_TOKEN      - Vercel account/team token (vercel.com/account/tokens)
#   VERCEL_ORG_ID     - from `vercel link`, written to .vercel/project.json
#   VERCEL_PROJECT_ID - from `vercel link`, written to .vercel/project.json
